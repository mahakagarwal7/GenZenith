# ============================================================
# NGO Volunteer Matching App - Environment Variables Example
# ============================================================
# SECURITY WARNING:
# - Do NOT commit real secrets to git.
# - Keep real values in local .env, CI/CD secret manager, or Supabase secrets.
# - Rotate keys/tokens if exposed.
#
# This file is safe to commit because it contains placeholders only.

# ------------------------------------------------------------
# Supabase (Core Project)
# ------------------------------------------------------------
# Supabase project URL from dashboard.
SUPABASE_URL=https://your-project-ref.supabase.co

# ------------------------------------------------------------
# Supabase Client Key (Public)
# ------------------------------------------------------------
# Public anonymous key for browser/mobile client usage.
SUPABASE_ANON_KEY=your_supabase_anon_key

# ------------------------------------------------------------
# Supabase Service Role Key (Private)
# ------------------------------------------------------------
# PRIVATE: server-side only (backend, cron jobs, edge/server functions).
# NEVER expose in frontend bundles or public repos.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Runtime defaults used by backend ingestion paths.
DEFAULT_NGO_ID=ngo_default
SUPABASE_NEED_EVIDENCE_BUCKET=need-evidence

# ------------------------------------------------------------
# Supabase Database URL (Direct Postgres)
# ------------------------------------------------------------
# For Python prediction service and trusted backend database access.
# Example format:
# postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# ------------------------------------------------------------
# Twilio (SMS / WhatsApp Notifications)
# ------------------------------------------------------------
# REQUIRED by notifyVolunteer service.
# Current code reads TWILIO_ACCOUNT_SID, TWILIO_SID, TWILIO_AUTH_TOKEN,
# TWILIO_PHONE_NUMBER, TWILIO_FROM_NUMBER.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+14155550123
TWILIO_FROM_NUMBER=+14155550123

# Requested WhatsApp sender format (for future WhatsApp webhook/send flow).
# Example: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155550123

# ------------------------------------------------------------
# Google Cloud Vision / OCR
# ------------------------------------------------------------
# If using direct API key auth for Vision API calls.
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key

# If using service account credentials locally (recommended for backend).
# Path to service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# ------------------------------------------------------------
# Google Maps Geocoding (CURRENTLY USED)
# ------------------------------------------------------------
# geocodeService.ts currently reads GOOGLE_MAPS_API_KEY or GOOGLE_MAPS_APIKEY.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_APIKEY=your_google_maps_api_key

# ------------------------------------------------------------
# Mapbox (Dashboard)
# ------------------------------------------------------------
# For dashboard maps and geospatial UI.
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
# Use true/false (lowercase) values.
FEATURE_ENABLE_OCR=true
FEATURE_ENABLE_MATCHING=true
FEATURE_DEBUG_MODE=false
ENABLE_SUPABASE_REALTIME=true
ENABLE_RLS=true

# ------------------------------------------------------------
# Supabase Table Names
# ------------------------------------------------------------
# Keep these aligned with backend constants to avoid runtime mismatches.
TABLE_NEEDS=needs
TABLE_VOLUNTEERS=volunteers
TABLE_MATCH_LOGS=match_logs
TABLE_USERS=users
TABLE_PREDICTIONS=predictions

# ------------------------------------------------------------
# Matching Algorithm Weights
# ------------------------------------------------------------
# Should sum to 1.0.
# Current service logic in intelligentMatchingService.ts uses:
# proximity 0.25, skill 0.25, availability 0.20, workload 0.15, fairness 0.15
MATCH_WEIGHT_PROXIMITY=0.25
MATCH_WEIGHT_SKILL=0.25
MATCH_WEIGHT_AVAILABILITY=0.20
MATCH_WEIGHT_WORKLOAD=0.15
MATCH_WEIGHT_FAIRNESS=0.15

# Optional tuning parameter
MATCH_MAX_DISTANCE_KM=10

# ------------------------------------------------------------
# Optional Runtime / Logging
# ------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=development

# ------------------------------------------------------------
# MIGRATION_NOTES.md
# ------------------------------------------------------------
# 1) Why SUPABASE_SERVICE_ROLE_KEY must stay server-side:
#    This key bypasses Row Level Security (RLS) and has elevated privileges.
#    If leaked to frontend/client apps, anyone can read/write protected data.
#
# 2) Local development runtime:
#    Use "supabase start" to run local Supabase services in Docker.
#    This mirrors production components for safer testing.
#
# 3) Security model update:
#    In Supabase, RLS policies on Postgres tables replace Firestore security rules.
#    Keep RLS enabled in production and review policies per role.

# ============================================================
# NGO Volunteer Matching App - Environment Variables Example
# ============================================================
# SECURITY WARNING:
# - Do NOT commit real secrets to git.
# - Keep real values in local .env, CI/CD secret manager, or Firebase config.
# - Rotate keys/tokens if exposed.
#
# This file is safe to commit because it contains placeholders only.

# ------------------------------------------------------------
# Firebase (Web / Dashboard Client)
# ------------------------------------------------------------
# Used by frontend dashboard app (if/when added).
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ------------------------------------------------------------
# Firebase (Server / Functions)
# ------------------------------------------------------------
# Used in tests and server runtime.
GCLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_PROJECT=your-project-id

# Optional: Firebase Emulator support
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ------------------------------------------------------------
# Twilio (SMS / WhatsApp Notifications)
# ------------------------------------------------------------
# REQUIRED by notifyVolunteer service.
# Current code reads TWILIO_ACCOUNT_SID, TWILIO_SID, TWILIO_AUTH_TOKEN,
# TWILIO_PHONE_NUMBER, TWILIO_FROM_NUMBER.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+14155550123
TWILIO_FROM_NUMBER=+14155550123

# Requested WhatsApp sender format (for future WhatsApp webhook/send flow).
# Example: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155550123

# ------------------------------------------------------------
# Google Cloud Vision / OCR
# ------------------------------------------------------------
# If using direct API key auth for Vision API calls.
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key

# If using service account credentials locally (recommended for backend).
# Path to service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# ------------------------------------------------------------
# Google Maps Geocoding (CURRENTLY USED)
# ------------------------------------------------------------
# geocodeService.ts currently reads GOOGLE_MAPS_API_KEY or GOOGLE_MAPS_APIKEY.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_APIKEY=your_google_maps_api_key

# ------------------------------------------------------------
# Mapbox (Dashboard)
# ------------------------------------------------------------
# For dashboard maps and geospatial UI.
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
# Use true/false (lowercase) values.
FEATURE_ENABLE_OCR=true
FEATURE_ENABLE_MATCHING=true
FEATURE_DEBUG_MODE=false

# ------------------------------------------------------------
# Firestore Collection Names
# ------------------------------------------------------------
# Keep these aligned with backend constants to avoid runtime mismatches.
COLLECTION_NEEDS_RAW=needs_raw
COLLECTION_VOLUNTEERS=volunteers
COLLECTION_MATCH_LOGS=match_logs
COLLECTION_USERS=users
COLLECTION_PREDICTIONS=predictions

# ------------------------------------------------------------
# Matching Algorithm Weights
# ------------------------------------------------------------
# Should sum to 1.0.
# Current service logic in intelligentMatchingService.ts uses:
# proximity 0.25, skill 0.25, availability 0.20, workload 0.15, fairness 0.15
MATCH_WEIGHT_PROXIMITY=0.25
MATCH_WEIGHT_SKILL=0.25
MATCH_WEIGHT_AVAILABILITY=0.20
MATCH_WEIGHT_WORKLOAD=0.15
MATCH_WEIGHT_FAIRNESS=0.15

# Optional tuning parameter
MATCH_MAX_DISTANCE_KM=10

# ------------------------------------------------------------
# Optional Runtime / Logging
# ------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=development

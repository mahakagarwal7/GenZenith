{
  "name": "ai-volunteer-functions",
  "version": "1.0.0",
  "description": "Supabase backend for AI Volunteer Intelligence Platform (Phase 1 MVP)",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "serve:whatsapp": "cd ../ && supabase functions serve whatsapp-webhook --env-file ../.env",
    "serve:volunteer-response": "cd ../ && supabase functions serve volunteer-response --env-file ../.env",
    "serve:need-created": "cd ../ && supabase functions serve need-created --env-file ../.env",
    "deploy:edge": "cd ../ && supabase functions deploy whatsapp-webhook && supabase functions deploy volunteer-response && supabase functions deploy need-created",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.0",
    "@supabase/supabase-js": "^2.104.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.3"
  },
  "private": true
}
